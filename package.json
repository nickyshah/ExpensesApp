{
  "name": "expenses-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "DATABASE_URL=${DATABASE_URL:-file:./server/data/expenses-app.db} prisma db push && node server.mjs",
    "build": "DATABASE_URL=${DATABASE_URL:-file:./server/data/expenses-app.db} prisma generate && next build",
    "start": "NODE_ENV=production node server.mjs",
    "api:dev": "DATABASE_URL=${DATABASE_URL:-file:./server/data/expenses-app.db} prisma db push && node --watch --no-warnings server/src/index.js",
    "postinstall": "DATABASE_URL=${DATABASE_URL:-file:./server/data/expenses-app.db} prisma generate",
    "db:push": "DATABASE_URL=${DATABASE_URL:-file:./server/data/expenses-app.db} prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "idb": "^8.0.0",
    "lucide-react": "^0.452.0",
    "multer": "^2.0.0",
    "next": "^15.1.0",
    "@prisma/client": "^6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.13"
  }
}
