# Expenses App Environment Variables
# Copy this file to .env and customise

# Port the server listens on (default: 3001)
PORT=3001

# Directory where the SQLite database is stored
# Default: ./server/data (relative to project root)
DATA_DIR=./server/data

# Prisma database URL (auto-set from DATA_DIR if omitted)
# DATABASE_URL=file:./server/data/expenses-app.db
